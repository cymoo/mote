{$DOMAIN} {
    encode gzip

    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Redirect bare root to the blog
    redir = / /shared 301

    # Redirect /memo (no trailing slash) to /memo/ for SPA router
    redir = /memo /memo/ 301

    # React SPA: strip /memo prefix, serve static files from bind-mounted web dir
    handle_path /memo/* {
        root * /srv/web

        # Long-lived cache for Vite fingerprinted assets
        @assets path /assets/*
        header @assets Cache-Control "public, max-age=31536000, immutable"

        try_files {path} /index.html
        file_server
    }

    # Everything else goes to the Go app
    handle {
        reverse_proxy app:8000
    }
}
