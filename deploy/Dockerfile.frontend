FROM node:22-alpine AS builder
WORKDIR /app
COPY frontend/package.json frontend/yarn.lock ./
COPY frontend/patches/ ./patches/
RUN yarn install --frozen-lockfile
COPY frontend/ .
ARG VITE_MEMO_URL=/memo
ARG VITE_BLOG_URL=/shared
ARG VITE_MANIFEST_START_URL=/memo
RUN VITE_MEMO_URL=$VITE_MEMO_URL \
    VITE_BLOG_URL=$VITE_BLOG_URL \
    VITE_MANIFEST_START_URL=$VITE_MANIFEST_START_URL \
    yarn build

FROM alpine
COPY --from=builder /app/dist /app/dist
